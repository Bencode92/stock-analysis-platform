  "market_conditions": {
    "_doc": "Règles conditionnelles évaluées à chaque run. Les données (brent, vix, gold) sont fetchées en début de pipeline. Chaque règle ajuste un thematic_cap ou un mandatory_hedge.",
    "rules": [
      {
        "id": "iran_escalation",
        "condition": "brent_usd > 100",
        "adjustments": [
          { "type": "thematic_cap_delta", "theme": "energy_oil", "delta_pct": 5, "profiles": ["Agressif", "Modéré"] },
          { "type": "mandatory_hedge_delta", "hedge": "gold", "delta_pct": 2, "profiles": ["Agressif", "Modéré"] }
        ],
        "_rationale": "Conflit Iran matérialisé. Energy surperforme, gold = hedge géopolitique."
      },
      {
        "id": "deescalation",
        "condition": "brent_usd < 85",
        "adjustments": [
          { "type": "thematic_cap_delta", "theme": "energy_oil", "delta_pct": -5, "profiles": ["Agressif", "Modéré"] }
        ],
        "_rationale": "Dé-escalation Iran. Réduire surpondération energy. Expert: XOM 10.3% → 7% si Brent < 85$."
      },
      {
        "id": "high_vol_regime",
        "condition": "vix > 30",
        "adjustments": [
          { "type": "mandatory_hedge_delta", "hedge": "gold", "delta_pct": 2, "profiles": ["Agressif", "Modéré", "Stable"] },
          { "type": "thematic_cap_delta", "theme": "semi_ai", "delta_pct": -5, "profiles": ["Agressif"] }
        ],
        "_rationale": "Vol élevée = renforcer hedges, réduire les paris directionnels."
      },
      {
        "id": "gold_correction",
        "condition": "gold_drawdown_from_ath_pct > 15",
        "adjustments": [
          { "type": "thematic_cap_delta", "theme": "precious_metals", "delta_pct": -3, "profiles": ["Agressif", "Modéré"] }
        ],
        "_rationale": "Or en correction technique (actuellement -18% du pic 5595$). Réduire exposition mais pas supprimer — thèse structurelle intacte."
      },
      {
        "id": "fed_dovish_pivot",
        "condition": "fed_funds_rate_delta_6m < -0.50",
        "adjustments": [
          { "type": "thematic_cap_delta", "theme": "semi_ai", "delta_pct": 5, "profiles": ["Agressif"] },
          { "type": "thematic_cap_delta", "theme": "dividend_value", "delta_pct": -3, "profiles": ["Modéré", "Stable"] }
        ],
        "_rationale": "Pivot Fed = retour tech/growth. Relâcher le cap semi, réduire le tilt value."
      }
    ]
  },

